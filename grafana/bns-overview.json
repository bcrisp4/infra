{
  "uid": "bns-overview",
  "title": "BNS — DNS Forwarder & Adblock",
  "tags": ["bns", "dns", "adblock"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "editable": true,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "PBFA97CFB590B2093" },
        "refresh": 1,
        "regex": "",
        "hide": 0
      },
      {
        "name": "job",
        "type": "query",
        "label": "Job",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(bns_queries_total, job)",
        "query": { "query": "label_values(bns_queries_total, job)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all", "selected": true },
        "options": [],
        "regex": "",
        "sort": 1
      },
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(bns_queries_total{job=~\"$job\"}, instance)",
        "query": { "query": "label_values(bns_queries_total{job=~\"$job\"}, instance)", "refId": "PrometheusVariableQueryEditor-VariableQuery" },
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all", "selected": true },
        "options": [],
        "regex": "",
        "sort": 1
      },
      {
        "name": "rate",
        "label": "Rate window",
        "type": "interval",
        "query": "1m,5m,15m,1h",
        "current": { "selected": true, "text": "5m", "value": "5m" },
        "options": [
          { "text": "1m", "value": "1m", "selected": false },
          { "text": "5m", "value": "5m", "selected": true },
          { "text": "15m", "value": "15m", "selected": false },
          { "text": "1h", "value": "1h", "selected": false }
        ],
        "auto": false,
        "auto_count": 30,
        "auto_min": "10s",
        "refresh": 2
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "type": "dashboard",
        "enable": true,
        "name": "Annotations & Alerts",
        "iconColor": "rgba(0, 211, 255, 1)"
      }
    ]
  },
  "panels": [
    { "id": 1, "type": "row", "title": "Overview", "collapsed": false, "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 } },
    { "id": 2, "type": "stat", "title": "Query rate", "gridPos": { "x": 0, "y": 1, "w": 3, "h": 4 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "qps", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] }, "options": { "reduceOptions": { "calc": "lastNotNull" }, "colorMode": "none", "graphMode": "area", "textMode": "auto" }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(bns_queries_total{job=~\"$job\", instance=~\"$instance\"}[$rate]))", "instant": true }] },
    { "id": 3, "type": "stat", "title": "Cache hit ratio", "gridPos": { "x": 3, "y": 1, "w": 3, "h": 4 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.5 }, { "color": "green", "value": 0.8 }] } }, "overrides": [] }, "options": { "reduceOptions": { "calc": "lastNotNull" }, "colorMode": "value", "graphMode": "area", "textMode": "auto" }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(bns_cache_lookups_total{result=\"hit\", job=~\"$job\", instance=~\"$instance\"}[$rate])) / clamp_min(sum(rate(bns_cache_lookups_total{job=~\"$job\", instance=~\"$instance\"}[$rate])), 1)", "instant": true }] },
    { "id": 4, "type": "stat", "title": "Block ratio", "gridPos": { "x": 6, "y": 1, "w": 3, "h": 4 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "fixed", "fixedColor": "purple" } }, "overrides": [] }, "options": { "reduceOptions": { "calc": "lastNotNull" }, "colorMode": "value", "graphMode": "area", "textMode": "auto" }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(bns_queries_total{outcome=\"blocked\", job=~\"$job\", instance=~\"$instance\"}[$rate])) / clamp_min(sum(rate(bns_queries_total{job=~\"$job\", instance=~\"$instance\"}[$rate])), 1)", "instant": true }] },
    { "id": 5, "type": "stat", "title": "p95 query latency", "gridPos": { "x": 9, "y": 1, "w": 3, "h": 4 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.05 }, { "color": "red", "value": 0.2 }] } }, "overrides": [] }, "options": { "reduceOptions": { "calc": "lastNotNull" }, "colorMode": "value", "graphMode": "area", "textMode": "auto" }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "histogram_quantile(0.95, sum(rate(bns_query_duration_seconds_bucket{job=~\"$job\", instance=~\"$instance\"}[$rate])) by (le))", "instant": true }] },
    { "id": 6, "type": "stat", "title": "Upstream error ratio", "gridPos": { "x": 12, "y": 1, "w": 3, "h": 4 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.05 }] } }, "overrides": [] }, "options": { "reduceOptions": { "calc": "lastNotNull" }, "colorMode": "value", "graphMode": "area", "textMode": "auto" }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(bns_upstream_queries_total{outcome=\"error\", job=~\"$job\", instance=~\"$instance\"}[$rate])) / clamp_min(sum(rate(bns_upstream_queries_total{job=~\"$job\", instance=~\"$instance\"}[$rate])), 1)", "instant": true }] },
    { "id": 7, "type": "stat", "title": "Cache utilisation", "gridPos": { "x": 15, "y": 1, "w": 3, "h": 4 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.85 }, { "color": "red", "value": 0.95 }] } }, "overrides": [] }, "options": { "reduceOptions": { "calc": "lastNotNull" }, "colorMode": "value", "graphMode": "area", "textMode": "auto" }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(bns_cache_entries{job=~\"$job\", instance=~\"$instance\"}) / clamp_min(sum(bns_cache_capacity{job=~\"$job\", instance=~\"$instance\"}), 1)", "instant": true }] },
    { "id": 8, "type": "stat", "title": "Blocklist size", "gridPos": { "x": 18, "y": 1, "w": 3, "h": 4 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } }, "overrides": [] }, "options": { "reduceOptions": { "calc": "lastNotNull" }, "colorMode": "value", "graphMode": "none", "textMode": "auto" }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "max(bns_blocklist_entries{job=~\"$job\", instance=~\"$instance\"})", "instant": true }] },
    { "id": 9, "type": "stat", "title": "Blocklist age (oldest)", "gridPos": { "x": 21, "y": 1, "w": 3, "h": 4 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 93600 }, { "color": "red", "value": 172800 }] } }, "overrides": [] }, "options": { "reduceOptions": { "calc": "lastNotNull" }, "colorMode": "value", "graphMode": "none", "textMode": "auto" }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "time() - min(bns_blocklist_loaded_timestamp_seconds{job=~\"$job\", instance=~\"$instance\"})", "instant": true }] },
    { "id": 10, "type": "row", "title": "Queries", "collapsed": false, "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 } },
    { "id": 11, "type": "timeseries", "title": "Query rate by outcome", "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "qps", "custom": { "drawStyle": "line", "fillOpacity": 25, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1 } }, "overrides": [] }, "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance, outcome) (rate(bns_queries_total{job=~\"$job\", instance=~\"$instance\"}[$rate]))", "legendFormat": "{{instance}} · {{outcome}}" }] },
    { "id": 12, "type": "timeseries", "title": "Query rate by type (qtype)", "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "qps", "custom": { "drawStyle": "line", "fillOpacity": 25, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1 } }, "overrides": [] }, "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance, qtype) (rate(bns_queries_total{job=~\"$job\", instance=~\"$instance\"}[$rate]))", "legendFormat": "{{instance}} · {{qtype}}" }] },
    { "id": 13, "type": "piechart", "title": "Outcome distribution", "gridPos": { "x": 0, "y": 14, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "qps" }, "overrides": [] }, "options": { "reduceOptions": { "calc": "lastNotNull" }, "pieType": "donut", "legend": { "displayMode": "list", "placement": "right", "values": ["percent"] }, "tooltip": { "mode": "single" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (outcome) (rate(bns_queries_total{job=~\"$job\", instance=~\"$instance\"}[$rate]))", "legendFormat": "{{outcome}}", "instant": true }] },
    { "id": 14, "type": "piechart", "title": "Query types", "gridPos": { "x": 12, "y": 14, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "qps" }, "overrides": [] }, "options": { "reduceOptions": { "calc": "lastNotNull" }, "pieType": "donut", "legend": { "displayMode": "list", "placement": "right", "values": ["percent"] }, "tooltip": { "mode": "single" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (qtype) (rate(bns_queries_total{job=~\"$job\", instance=~\"$instance\"}[$rate]))", "legendFormat": "{{qtype}}", "instant": true }] },
    { "id": 15, "type": "row", "title": "Ad-blocking", "collapsed": false, "gridPos": { "x": 0, "y": 22, "w": 24, "h": 1 } },
    { "id": 16, "type": "timeseries", "title": "Blocked vs allowed", "gridPos": { "x": 0, "y": 23, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "qps", "custom": { "drawStyle": "line", "fillOpacity": 25, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1 } }, "overrides": [{ "matcher": { "id": "byRegexp", "options": ".*blocked.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }, { "matcher": { "id": "byRegexp", "options": ".*allowed.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }] }, "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance) (rate(bns_queries_total{outcome=\"blocked\", job=~\"$job\", instance=~\"$instance\"}[$rate]))", "legendFormat": "{{instance}} · blocked" }, { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance) (rate(bns_queries_total{outcome!=\"blocked\", job=~\"$job\", instance=~\"$instance\"}[$rate]))", "legendFormat": "{{instance}} · allowed" }] },
    { "id": 17, "type": "timeseries", "title": "Block ratio over time", "gridPos": { "x": 12, "y": 23, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "gradientMode": "opacity" } }, "overrides": [] }, "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance) (rate(bns_queries_total{outcome=\"blocked\", job=~\"$job\", instance=~\"$instance\"}[$rate])) / clamp_min(sum by (instance) (rate(bns_queries_total{job=~\"$job\", instance=~\"$instance\"}[$rate])), 1)", "legendFormat": "{{instance}}" }] },
    { "id": 18, "type": "timeseries", "title": "Blocklist entries (total + by source)", "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0, "lineWidth": 2 } }, "overrides": [] }, "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance) (bns_blocklist_entries{job=~\"$job\", instance=~\"$instance\"})", "legendFormat": "{{instance}} · total (deduped)" }, { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance, source) (bns_blocklist_entries_by_source{job=~\"$job\", instance=~\"$instance\"})", "legendFormat": "{{instance}} · {{source}}" }] },
    { "id": 19, "type": "timeseries", "title": "Blocklist reloads (cumulative)", "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 0, "lineWidth": 2, "pointSize": 6, "showPoints": "always" } }, "overrides": [{ "matcher": { "id": "byRegexp", "options": ".*error.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }, { "matcher": { "id": "byRegexp", "options": ".*ok.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }] }, "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance, outcome) (bns_blocklist_reloads_total{job=~\"$job\", instance=~\"$instance\"})", "legendFormat": "{{instance}} · {{outcome}}" }] },
    { "id": 20, "type": "timeseries", "title": "Blocklist fetches by source (cumulative)", "gridPos": { "x": 0, "y": 39, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 0, "lineWidth": 2, "pointSize": 6, "showPoints": "always" } }, "overrides": [{ "matcher": { "id": "byRegexp", "options": ".*failure.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] }] }, "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance, source, outcome) (bns_blocklist_fetch_total{job=~\"$job\", instance=~\"$instance\"})", "legendFormat": "{{instance}} · {{source}} · {{outcome}}" }] },
    { "id": 21, "type": "stat", "title": "Per-source freshness (time since last good fetch)", "gridPos": { "x": 12, "y": 39, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 93600 }, { "color": "red", "value": 172800 }] } }, "overrides": [] }, "options": { "reduceOptions": { "calc": "lastNotNull" }, "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "orientation": "horizontal" }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "time() - bns_blocklist_last_success_timestamp_seconds{job=~\"$job\", instance=~\"$instance\"}", "legendFormat": "{{instance}} · {{source}}", "instant": true }] },
    { "id": 22, "type": "row", "title": "Cache", "collapsed": false, "gridPos": { "x": 0, "y": 47, "w": 24, "h": 1 } },
    { "id": 23, "type": "timeseries", "title": "Cache hit ratio over time", "gridPos": { "x": 0, "y": 48, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2, "gradientMode": "opacity" } }, "overrides": [] }, "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance) (rate(bns_cache_lookups_total{result=\"hit\", job=~\"$job\", instance=~\"$instance\"}[$rate])) / clamp_min(sum by (instance) (rate(bns_cache_lookups_total{job=~\"$job\", instance=~\"$instance\"}[$rate])), 1)", "legendFormat": "{{instance}}" }] },
    { "id": 24, "type": "timeseries", "title": "Cache lookups (hit vs miss)", "gridPos": { "x": 12, "y": 48, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 25, "stacking": { "mode": "normal", "group": "A" }, "lineWidth": 1 } }, "overrides": [{ "matcher": { "id": "byRegexp", "options": ".*hit.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] }, { "matcher": { "id": "byRegexp", "options": ".*miss.*" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }] }, "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean"] }, "tooltip": { "mode": "multi" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance, result) (rate(bns_cache_lookups_total{job=~\"$job\", instance=~\"$instance\"}[$rate]))", "legendFormat": "{{instance}} · {{result}}" }] },
    { "id": 25, "type": "timeseries", "title": "Cache entries vs capacity", "gridPos": { "x": 0, "y": 56, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 } }, "overrides": [{ "matcher": { "id": "byRegexp", "options": ".*capacity.*" }, "properties": [{ "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } }, { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }, { "id": "custom.fillOpacity", "value": 0 }] }] }, "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance) (bns_cache_entries{job=~\"$job\", instance=~\"$instance\"})", "legendFormat": "{{instance}} · entries" }, { "refId": "B", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance) (bns_cache_capacity{job=~\"$job\", instance=~\"$instance\"})", "legendFormat": "{{instance}} · capacity" }] },
    { "id": 26, "type": "timeseries", "title": "Cache eviction rate", "gridPos": { "x": 12, "y": 56, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 25, "lineWidth": 1, "gradientMode": "opacity" } }, "overrides": [] }, "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance) (rate(bns_cache_evictions_total{job=~\"$job\", instance=~\"$instance\"}[$rate]))", "legendFormat": "{{instance}}" }] },
    { "id": 27, "type": "timeseries", "title": "Coalesced (deduped) queries", "gridPos": { "x": 0, "y": 64, "w": 12, "h": 8 }, "datasource": { "type": "prometheus", "uid": "${datasource}" }, "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 25, "lineWidth": 1, "gradientMode": "opacity" } }, "overrides": [] }, "options": { "legend": { "displayMode": "list", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } }, "targets": [{ "refId": "A", "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum by (instance) (rate(bns_coalesced_queries_total{job=~\"$job\", instance=~\"$instance\"}[$rate]))", "legendFormat": "{{instance}}" }] },
